# Amplifier intelligence service — required environment variables
#
# docker-compose.yml reads these directly from the host environment
# using ${VAR:-} syntax. Set them in your shell before running
# docker-compose up, or export them in your .bashrc / .zshrc.
#
# For GH_TOKEN, you can use the GitHub CLI:
#   export GH_TOKEN=$(gh auth token)
#
# Required:
#   ANTHROPIC_API_KEY    — at minimum one provider key is needed
#
# Optional (enable additional providers):
#   GOOGLE_API_KEY
#   OPENAI_API_KEY
#   AZURE_OPENAI_API_KEY
#   GH_TOKEN
