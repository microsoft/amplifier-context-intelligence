# Stage 1: Build
FROM node:22-alpine AS build
WORKDIR /app
COPY amplifier-context-intelligence/frontend/package.json amplifier-context-intelligence/frontend/package-lock.json* ./
RUN npm ci
COPY amplifier-context-intelligence/frontend/ .
RUN npm run build

# Stage 2: Serve
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY amplifier-context-intelligence/frontend/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
