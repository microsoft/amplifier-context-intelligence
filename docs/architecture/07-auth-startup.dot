digraph auth_startup {
    // -- Global defaults -----------------------------------------------------------
    graph [
        rankdir   = TB
        splines   = ortho
        compound  = true
        nodesep   = 0.55
        ranksep   = 0.80
        fontname  = "Helvetica"
        fontsize  = 11
        label     = "Auth Wiring at Boot \u2014 Mode Selection & Fail-Closed Startup Gates\n(context_intelligence_server/main.py \u2014 create_asgi_app()  \u00b7  auth.py \u2014 resolvers)\nM2: dual-map construction (entra_identities + service_identities) + B4 disjointness gate before JWKS prefetch"
        labelloc  = t
        labeljust = c
    ]
    node [
        fontname = "Helvetica"
        fontsize = 11
        style    = "filled,rounded"
        shape    = box
    ]
    edge [
        fontname = "Helvetica"
        fontsize = 10
    ]

    // ====================================================================
    // ENTRY
    // ====================================================================
    Entry [
        label     = "create_asgi_app(settings)\n(called once at module load \u2014 main.py line 286:\nasgi_app = create_asgi_app())"
        shape     = oval
        fillcolor = "#E3F2FD"
    ]

    // ====================================================================
    // AUTH MODE SELECTION
    // ====================================================================
    AuthModeSwitch [
        label     = "settings.auth_mode?"
        shape     = diamond
        fillcolor = "#FFF9C4"
        style     = filled
    ]

    // ====================================================================
    // STATIC KEY RESOLVER CONSTRUCTION  (auth_mode=static)
    // ====================================================================
    subgraph cluster_static_build {
        graph [
            label     = "StaticKeyResolver  (auth_mode=static)  \u2014 auth.py\nPre-shared bearer tokens; no network calls at startup"
            style     = "filled"
            color     = "#546E7A"
            fillcolor = "#ECEFF1"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        BuildKeystore [
            label     = "settings.build_keystore()\nsha256(token) \u2192 contributor_id map\n(from api_key / api_keys config)"
            fillcolor = "#F5F5F5"
        ]

        StaticResolver [
            label     = "StaticKeyResolver(keystore)\nauth_enabled = bool(keystore)\n  True  \u2193 \u22651 key configured\n  False \u2193 empty keystore (allow_unauthenticated opt-out only)"
            fillcolor = "#ECEFF1"
            fontname  = "Helvetica-Bold"
        ]
    }

    // ====================================================================
    // ENTRA RESOLVER CONSTRUCTION  (auth_mode=entra)
    // M2: dual-map build + B4 disjointness gate + JWKS prefetch
    // ====================================================================
    subgraph cluster_entra_build {
        graph [
            label     = "EntraResolver  (auth_mode=entra)  \u2014 auth.py\nM2: both identity maps built from config; B4 disjointness gate; JWKS fetched eagerly (fail-closed)"
            style     = "filled"
            color     = "#0D47A1"
            fillcolor = "#E3F2FD"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        // Force parallel layout for the two map-build steps
        { rank = same; BuildIdentityMap; BuildServiceMap }

        BuildIdentityMap [
            label     = "settings.build_identity_map()\n{oid_lower \u2192 contributor_id}\n(from entra_identities config; keys lowercased)\nLIVE via IdentityStore.flat_dict \u2014 runtime-mutable by /admin/*"
            fillcolor = "#BBDEFB"
        ]

        BuildServiceMap [
            label     = "build_service_identity_map()\n{oid_lower \u2192 friendly_name}\n(from service_identities config; keys lowercased)\nPLAIN DICT \u2014 NOT an IdentityStore, NO durable file\nStatic config only; empty dict if not configured\nNo /admin/services \u2014 managed by config change + redeploy"
            fillcolor = "#BBDEFB"
        ]

        // B4: Disjointness invariant -- fail-closed gate
        DisjointCheck [
            label     = "B4: disjointness invariant\nentra_identities.keys() \u2229 service_identities.keys() = \u2205?\n(same oid in both maps \u2192 name collision at resolve time)\nfail-closed: any overlap \u2192 RuntimeError; server refuses to start\n\u2014\nNote: B1 (idtyp-first branch) is the security-critical\nhuman/service separation; B4 guards friendly-name hygiene"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        BuildJwksClient [
            label     = "PyJWKClient(\n  uri=https://login.microsoftonline.com/{tenant_id}/discovery/v2.0/keys\n  lifespan=JWKS_CACHE_LIFESPAN_SECONDS  [300 s]\n)"
            fillcolor = "#BBDEFB"
        ]

        EagerFetch [
            label     = "jwks_client.fetch_data()\nEAGER prefetch \u2014 fail-closed at startup\n(\u00a78b / crusty gate)"
            fillcolor = "#80CBC4"
            fontname  = "Helvetica-Bold"
        ]

        FetchOk [
            label     = "JWKS reachable?"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        ZeroKeysCheck [
            label     = "jwks_client.get_jwk_set().keys\nnon-empty?"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        EntraResolver [
            label     = "EntraResolver(\n  client_id, tenant_id,\n  identity_map,          \u2190 entra flat_dict (live \u2014 via IdentityStore)\n  service_identity_map,  \u2190 plain dict from config (static, read-only)\n  service_data_role,     \u2190 \"Contributor\" (default)\n  reader_role,           \u2190 \"Reader\"\n  entra_admin_role       \u2190 e.g. \"IdentityAdmin\"\n)\nauth_enabled = True  (always \u2014 identity_map non-empty by config validation)\nexpected_aud = [client_id, \"api://client_id\"]\nexpected_issuer = https://login.microsoftonline.com/{tenant_id}/v2.0"
            fillcolor = "#BBDEFB"
            fontname  = "Helvetica-Bold"
        ]
    }

    // ====================================================================
    // FAIL-CLOSED STARTUP GATE
    // ====================================================================
    subgraph cluster_failclosed {
        graph [
            label     = "Fail-closed startup gate  (main.py \u2014 create_asgi_app)\nserver must refuse to boot unauthenticated in production"
            style     = "filled"
            color     = "#B71C1C"
            fillcolor = "#FFEBEE"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        AuthEnabledCheck [
            label     = "resolver.auth_enabled?"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        AllowUnauthCheck [
            label     = "settings.allow_unauthenticated?\n(test/dev opt-out ONLY \u2014 never set in production)"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]
    }

    // ====================================================================
    // EXEMPT PATH SET  (headless \u2014 single fixed set, no web_ui_enabled)
    // ====================================================================
    subgraph cluster_exempt {
        graph [
            label     = "Exempt-path set  (auth.py \u2014 _EXEMPT_PATHS)\nheadless / API-only: one fixed frozenset, no web_ui_enabled branch"
            style     = "filled"
            color     = "#006064"
            fillcolor = "#E0F7FA"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        ExemptFixed [
            label     = "exempt = _EXEMPT_PATHS  (fixed frozenset)\n{/status, /version, /docs, /openapi.json}\nFastAPI: docs_url=\"/docs\"\n  redoc_url=None  (ReDoc disabled)\n  openapi_url=\"/openapi.json\"\nAlways on: /docs (Swagger UI) + /openapi.json spec\nNo web routes, no StaticFiles mount\n_EXEMPT_PREFIXES = ()  (no prefix exemptions)"
            fillcolor = "#B2EBF2"
            fontname  = "Helvetica-Bold"
        ]
    }

    // ====================================================================
    // ASSEMBLY
    // ====================================================================
    subgraph cluster_assembly {
        graph [
            label     = "Middleware assembly  (auth.py \u2014 BearerTokenMiddleware)"
            style     = "filled"
            color     = "#006064"
            fillcolor = "#E0F7FA"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        MiddlewareWrap [
            label     = "BearerTokenMiddleware(\n  app,                   \u2190 FastAPI ASGI app\n  resolver=resolver,     \u2190 active resolver\n  exempt_paths=exempt    \u2190 mode-selected set\n)"
            fillcolor = "#80CBC4"
            fontname  = "Helvetica-Bold"
        ]
    }

    // ====================================================================
    // OUTPUT
    // ====================================================================
    AsgiApp [
        label     = "asgi_app  (module-level)\nserved by Gunicorn + UvicornWorker\nbind=settings.server_host:settings.server_port\nworkers=1  (validated by _validate_single_worker)"
        shape     = oval
        fillcolor = "#C8E6C9"
        fontname  = "Helvetica-Bold"
        penwidth  = 2.5
    ]

    // ====================================================================
    // FAILURE EXIT NODES
    // ====================================================================
    DisjointFail [
        label     = "RuntimeError\n\"boot invariant B4: oid(s) appear in both\n entra_identities and service_identities\n \u2014 maps must be disjoint; server cannot start\"\nprocess exits \u2014 start refused"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    JwksFetchFail [
        label     = "RuntimeError\n\"JWKS prefetch failed for tenant ...\n server cannot start\"\nprocess exits \u2014 start refused"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    ZeroKeysFail [
        label     = "RuntimeError\n\"JWKS endpoint returned zero signing keys ...\n server cannot start\"\nprocess exits \u2014 start refused"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    NoAuthFail [
        label     = "RuntimeError\n\"No authentication configured \u2014\n the server refuses to start\"\nprocess exits \u2014 start refused"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    // ====================================================================
    // FLOW EDGES
    // ====================================================================
    Entry           -> AuthModeSwitch

    // auth_mode branch
    AuthModeSwitch  -> BuildKeystore    [label = "\"static\"\n(default)"]
    AuthModeSwitch  -> BuildIdentityMap [label = "\"entra\""]
    AuthModeSwitch  -> BuildServiceMap  [label = "\"entra\""]

    // Static path
    BuildKeystore   -> StaticResolver

    // Entra path: build BOTH maps in parallel, then B4 disjointness check
    BuildIdentityMap -> DisjointCheck
    BuildServiceMap  -> DisjointCheck
    DisjointCheck    -> DisjointFail    [label = "overlap\n(\u2229 \u2260 \u2205)\n\u2192 RuntimeError", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    DisjointCheck    -> BuildJwksClient [label = "disjoint\n(\u2229 = \u2205)\n\u2192 proceed"]

    // JWKS prefetch (fail-closed)
    BuildJwksClient  -> EagerFetch
    EagerFetch       -> FetchOk

    FetchOk          -> ZeroKeysCheck    [label = "reachable"]
    FetchOk          -> JwksFetchFail    [label = "any exception\n(network / DNS / TLS)"]

    ZeroKeysCheck    -> EntraResolver    [label = "non-empty"]
    ZeroKeysCheck    -> ZeroKeysFail     [label = "empty {\"keys\": []}"]

    // Both paths converge at fail-closed gate
    StaticResolver   -> AuthEnabledCheck
    EntraResolver    -> AuthEnabledCheck

    // Fail-closed gate
    AuthEnabledCheck -> AllowUnauthCheck [label = "False\n(no credentials)"]
    AuthEnabledCheck -> ExemptFixed      [label = "True"]
    AllowUnauthCheck -> NoAuthFail       [label = "False\n(default \u2014 refuse to start)"]
    AllowUnauthCheck -> ExemptFixed      [label = "True\n(test/dev only)"]

    // Assembly \u2014 single fixed exempt set (headless)
    ExemptFixed      -> MiddlewareWrap

    // Output
    MiddlewareWrap   -> AsgiApp

    // ====================================================================
    // LEGEND
    // ====================================================================
    subgraph cluster_legend {
        graph [
            label     = "Legend"
            fontsize  = 10
            fontname  = "Helvetica"
            style     = "dashed"
            color     = "#AAAAAA"
        ]
        node [fontsize = 10]

        LegGrey [
            label     = "StaticKeyResolver"
            fillcolor = "#ECEFF1"
        ]
        LegBlue [
            label     = "EntraResolver / Entra JWT validation\n(identity_map + service_identity_map\n+ role params \u2014 M2)"
            fillcolor = "#BBDEFB"
        ]
        LegTeal [
            label     = "auth middleware\n/ exempt paths"
            fillcolor = "#B2EBF2"
        ]
        LegGreen [
            label     = "asgi_app output\n(server ready)"
            fillcolor = "#C8E6C9"
            fontname  = "Helvetica-Bold"
            penwidth  = 2.5
        ]
        LegError [
            label     = "startup refused\n(RuntimeError)"
            shape     = oval
            fillcolor = "#FFCCBC"
        ]
        LegDecision [
            label     = "decision / gate\n(incl. B4 disjointness)"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        LegGrey -> LegBlue -> LegTeal -> LegGreen -> LegError -> LegDecision [style = invis]
    }
}
