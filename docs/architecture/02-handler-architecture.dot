digraph handler_architecture {
    // ─── Global defaults ─────────────────────────────────────────────────────
    graph [
        rankdir   = TB
        splines   = ortho
        nodesep   = 0.8
        ranksep   = 0.9
        fontname  = "Helvetica"
        fontsize  = 11
        label     = "Handler & Router Architecture\n(layer-based organisation)"
        labelloc  = t
        labeljust = c
    ]
    node [
        fontname = "Helvetica"
        fontsize = 11
        style    = "filled,rounded"
        shape    = box
    ]
    edge [
        fontname = "Helvetica"
        fontsize = 10
    ]

    // ─── PipelineHandlers (NamedTuple record) ──────────────────────────────
    PipelineHandlers [
        shape     = record
        style     = "filled"
        fillcolor = "#E3F2FD"
        label     = "{PipelineHandlers (NamedTuple) | default: DefaultHandler | enrichers: list[Handler]}"
    ]

    // ─── Shared contract ──────────────────────────────────────────────────
    subgraph cluster_protocol {
        graph [
            label     = "Shared Contract\ncontext_intelligence_server/protocol.py"
            style     = "dashed"
            color     = "#90CAF9"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        Protocol [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#BBDEFB"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>EventHandler (Protocol)</B></TD></TR>
                <TR><TD>handled_events: AbstractSet[str]</TD></TR>
                <TR><TD>services: HookStateService</TD></TR>
                <TR><TD>async __call__(event, data) &#8594; HookResult</TD></TR>
            </TABLE>>
        ]
    }

    // ─── Routers (separate from event handling) ──────────────────────────
    subgraph cluster_routers {
        graph [
            label     = "routers/\nFastAPI HTTP endpoints (separate concern)"
            style     = "filled"
            color     = "#E0E0E0"
            fillcolor = "#FAFAFA"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        SkillsRouter [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#E0E0E0"
            label     = "skills.py\nSkillRegistry + GET /skills/{name}"
        ]

        VersionRouter [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#E0E0E0"
            label     = "version.py\nGET /version"
        ]
    }

    // ─── Data Layer 1: Raw event capture ─────────────────────────────────
    subgraph cluster_data_layer_1 {
        graph [
            label     = "handlers/data_layer_1/\nRaw event capture"
            style     = "filled"
            color     = "#81C784"
            fillcolor = "#E8F5E9"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        DefaultHandler [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#C8E6C9"
            fontname  = "Helvetica-Bold"
            penwidth  = 2.5
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>DefaultHandler</B></TD></TR>
                <TR><TD>UNCONDITIONAL &#8212; ALL events</TD></TR>
                <TR><TD>handled_events = set() (empty &#8212; accepts everything)</TD></TR>
                <TR><TD>9 FieldLifters &#8212; ALL matching fire</TD></TR>
                <TR><TD>Creates [:Event] node + lifted top-level props</TD></TR>
                <TR><TD>Creates (Session)-[:HAS_EVENT]-&gt;(Event) edge</TD></TR>
            </TABLE>>
        ]

        FieldLifters [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#A5D6A7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>field_lifters/</B></TD></TR>
                <TR><TD>UniversalLifter(*) | ArtifactLifter(artifact:*)</TD></TR>
                <TR><TD>DelegateLifter(delegate:*) | LlmLifter(llm:*)</TD></TR>
                <TR><TD>PromptLifter(prompt:*) | RecipeLifter(recipe:*)</TD></TR>
                <TR><TD>SessionLifter(session:*) | SkillLifter(skill:*)</TD></TR>
                <TR><TD>ToolLifter(tool:*)</TD></TR>
            </TABLE>>
        ]

        DefaultHandler -> FieldLifters [label = "delegates field\nextraction to"]
    }

    // ─── Data Layer 2: Semantic enrichment ───────────────────────────────
    subgraph cluster_data_layer_2 {
        graph [
            label     = "handlers/data_layer_2/\nSemantic enrichment"
            style     = "filled"
            color     = "#CE93D8"
            fillcolor = "#F3E5F5"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        SessionHandler [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>SessionHandler [0]</B></TD></TR>
                <TR><TD>session:start | session:fork | session:end</TD></TR>
                <TR><TD>Labels: RootSession | SubSession | ForkedSession</TD></TR>
                <TR><TD>Edges: SUBSESSION_OF | HAS_FORK</TD></TR>
            </TABLE>>
        ]

        ToolCallHandler [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>ToolCallHandler [1]</B></TD></TR>
                <TR><TD>tool:pre | tool:post | tool:error</TD></TR>
                <TR><TD>Node: :ToolCall</TD></TR>
                <TR><TD>Edges: HAS_TOOL_CALL | HAS_EVENT</TD></TR>
            </TABLE>>
        ]

        FutureHandler [
            shape     = box
            style     = "filled,rounded,dashed"
            fillcolor = "#FAFAFA"
            color     = "#AAAAAA"
            fontcolor = "#AAAAAA"
            label     = "FutureHandler [N]\n… extension point …\n(new handlers land here)"
        ]
    }

    // ─── Warning note ─────────────────────────────────────────────────────
    warning_note [
        shape     = box
        style     = "filled"
        fillcolor = "#FFF9C4"
        label     = "⚠ IMPORTANT\nClaiming an event does NOT prevent\nDefaultHandler from running.\nEnrichers are ADDITIVE — DefaultHandler\nalways creates the base Event node first."
    ]

    subgraph cluster_legend {
        graph [
            label     = "Legend"
            style     = "filled"
            color     = "#BDBDBD"
            fillcolor = "#F5F5F5"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        legend_contract [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#BBDEFB"
            label     = "blue = shared contract\n(protocol.py)"
        ]
        legend_capture [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#C8E6C9"
            label     = "green = raw capture\n(data_layer_1)"
        ]
        legend_enrich [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = "purple = semantic enrichment\n(data_layer_2)"
        ]
        legend_http [
            shape     = box
            style     = "filled,rounded"
            fillcolor = "#E0E0E0"
            label     = "grey = HTTP routers\n(separate concern)"
        ]
        legend_warning [
            shape     = box
            style     = "filled"
            fillcolor = "#FFF9C4"
            label     = "yellow = warning note"
        ]
    }

    // ─── Edges ────────────────────────────────────────────────────────────
    PipelineHandlers -> DefaultHandler   [label = "default"]
    PipelineHandlers -> SessionHandler   [label = "enrichers[0]"]
    PipelineHandlers -> ToolCallHandler  [label = "enrichers[1]"]
    ToolCallHandler  -> FutureHandler    [style = dashed, color = "#AAAAAA"]
    DefaultHandler   -> warning_note     [style = dotted, color = "#AAAAAA", arrowhead = none]

    // Protocol conformance
    DefaultHandler   -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    SessionHandler   -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    ToolCallHandler  -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
}
