digraph handler_architecture {
    // --- Global defaults ------------------------------------------------------
    graph [
        rankdir   = TB
        splines   = ortho
        nodesep   = 0.7
        ranksep   = 1.0
        fontname  = "Helvetica"
        fontsize  = 11
        label     = "Handler & Router Architecture\n(context_intelligence_server/pipeline.py \u2014 setup_handlers())"
        labelloc  = t
        labeljust = c
    ]
    node [
        fontname = "Helvetica"
        fontsize = 11
        style    = "filled,rounded"
        shape    = box
    ]
    edge [
        fontname = "Helvetica"
        fontsize = 10
    ]

    // --- PipelineHandlers (NamedTuple) ----------------------------------------
    PipelineHandlers [
        style     = "filled,rounded"
        fillcolor = "#E3F2FD"
        label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
            <TR><TD><B>PipelineHandlers (NamedTuple)</B></TD></TR>
            <TR><TD>default: DefaultHandler</TD></TR>
            <TR><TD>enrichers: list[Handler] &#8212; 12 enrichers total (8 data_layer_2 + 4 data_layer_3)</TD></TR>
        </TABLE>>
    ]

    // --- Shared Contract -----------------------------------------------------
    subgraph cluster_protocol {
        graph [
            label     = "Shared Contract\ncontext_intelligence_server/protocol.py"
            style     = "dashed"
            color     = "#90CAF9"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        Protocol [
            style     = "filled,rounded"
            fillcolor = "#BBDEFB"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>EventHandler (Protocol)</B></TD></TR>
                <TR><TD>handled_events: AbstractSet[str]</TD></TR>
                <TR><TD>services: HookStateService</TD></TR>
                <TR><TD>async __call__(event, data) &#8594; HookResult</TD></TR>
            </TABLE>>
        ]
    }

    // --- Routers (separate concern) ------------------------------------------
    subgraph cluster_routers {
        graph [
            label     = "routers/\nFastAPI HTTP endpoints (separate concern)"
            style     = "filled"
            color     = "#E0E0E0"
            fillcolor = "#FAFAFA"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        SkillsRouter [
            style     = "filled,rounded"
            fillcolor = "#E0E0E0"
            label     = "skills.py\nSkillRegistry + GET /skills/{name}"
        ]

        VersionRouter [
            style     = "filled,rounded"
            fillcolor = "#E0E0E0"
            label     = "version.py\nGET /version"
        ]

        QueuesRouter [
            style     = "filled,rounded"
            fillcolor = "#E0E0E0"
            label     = "QueuesRouter\n(routers/queues.py)\nGET /queues/dead-letter\nPOST .../replay | .../purge\n[Bearer auth]"
        ]

        SkillsRouter -> VersionRouter -> QueuesRouter [style = invis]
    }

    // --- Data Layer 1: Raw event capture ------------------------------------
    subgraph cluster_data_layer_1 {
        graph [
            label     = "handlers/data_layer_1/\nRaw event capture"
            style     = "filled"
            color     = "#81C784"
            fillcolor = "#E8F5E9"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        DefaultHandler [
            style     = "filled,rounded"
            fillcolor = "#C8E6C9"
            fontname  = "Helvetica-Bold"
            penwidth  = 2.5
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>DefaultHandler</B></TD></TR>
                <TR><TD>UNCONDITIONAL &#8212; ALL events</TD></TR>
                <TR><TD>handled_events = set() (empty &#8212; accepts everything)</TD></TR>
                <TR><TD>9 FieldLifters &#8212; ALL matching fire</TD></TR>
                <TR><TD>Creates [:Event] node + lifted top-level props</TD></TR>
                <TR><TD>Creates (Session)-[:HAS_EVENT]-&gt;(Event) edge</TD></TR>
            </TABLE>>
        ]

        FieldLifters [
            style     = "filled,rounded"
            fillcolor = "#A5D6A7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>field_lifters/</B></TD></TR>
                <TR><TD>UniversalLifter(*) | ArtifactLifter(artifact:*)</TD></TR>
                <TR><TD>DelegateLifter(delegate:*) | LlmLifter(llm:*)</TD></TR>
                <TR><TD>PromptLifter(prompt:*) | RecipeLifter(recipe:*)</TD></TR>
                <TR><TD>SessionLifter(session:*) | SkillLifter(skill:*)</TD></TR>
                <TR><TD>ToolLifter(tool:*)</TD></TR>
            </TABLE>>
        ]

        DefaultHandler -> FieldLifters [label = "delegates field\nextraction to"]
    }

    // --- Data Layer 2: Semantic enrichment ----------------------------------
    subgraph cluster_data_layer_2 {
        graph [
            label     = "handlers/data_layer_2/\nSemantic enrichment (8 enrichers)"
            style     = "filled"
            color     = "#CE93D8"
            fillcolor = "#F3E5F5"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        SessionHandler [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>SessionHandler [0]</B></TD></TR>
                <TR><TD>session:start | session:fork | session:end</TD></TR>
                <TR><TD>Labels: RootSession | SubSession | ForkedSession</TD></TR>
                <TR><TD>Edges: HAS_SUBSESSION (E13) | FORKED (E02)</TD></TR>
            </TABLE>>
        ]

        OrchestratorRunHandler [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>OrchestratorRunHandler [1]</B></TD></TR>
                <TR><TD>execution:start | execution:end | orchestrator:complete</TD></TR>
                <TR><TD>Node: :OrchestratorRun :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_EXECUTION (E01) | HAS_ATTRIBUTE (E03) | TRIGGERS (E14)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Writes: execution_start_ts, last_completed_orch_run_id</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads:  last_prompt_id</I></TD></TR>
            </TABLE>>
        ]

        IterationHandler [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>IterationHandler [2]</B></TD></TR>
                <TR><TD>provider:request | llm:request | llm:response</TD></TR>
                <TR><TD>Node: :Iteration :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_PART (E06)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Writes: active_iteration_id, iteration_count</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads:  execution_start_ts</I></TD></TR>
            </TABLE>>
        ]

        ContentBlockHandler [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>ContentBlockHandler [3]</B></TD></TR>
                <TR><TD>content_block:start | content_block:end</TD></TR>
                <TR><TD>Node: :ContentBlock :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_PART (E07)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads:  active_iteration_id</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Writes: pending_tool_block_ids</I></TD></TR>
            </TABLE>>
        ]

        ToolCallHandler [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>ToolCallHandler [4]</B></TD></TR>
                <TR><TD>tool:pre | tool:post</TD></TR>
                <TR><TD>Node: :ToolCall :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_TOOL_CALL (E08) | CAUSED (E09) | PARALLEL_EXECUTION (E10)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads:  active_iteration_id, pending_tool_block_ids</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Intra-handler: _parallel_groups dict</I></TD></TR>
            </TABLE>>
        ]

        PromptHandler [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>PromptHandler [5]</B></TD></TR>
                <TR><TD>prompt:submit</TD></TR>
                <TR><TD>Node: :Prompt :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_PART (E05) | ENABLES (E15)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads:  last_completed_orch_run_id</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Writes: last_prompt_id</I></TD></TR>
            </TABLE>>
        ]

        CancellationHandler [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>CancellationHandler [6]</B></TD></TR>
                <TR><TD>cancel:completed</TD></TR>
                <TR><TD>Node: :Cancellation :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_PART (E11)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>No state read/write</I></TD></TR>
            </TABLE>>
        ]

        ContextCompactionHandler [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>ContextCompactionHandler [7]</B></TD></TR>
                <TR><TD>context:pre_compact | context:post_compact</TD></TR>
                <TR><TD>Node: :ContextCompaction :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_COMPACTION (E12)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>No state read/write</I></TD></TR>
            </TABLE>>
        ]
    }

    // --- Data Layer 3: Delegation, Skills & Recipes enrichment ---------------
    subgraph cluster_data_layer_3 {
        graph [
            label     = "handlers/data_layer_3/\nDelegation, Skills & Recipes enrichment (4 enrichers)"
            style     = "filled"
            color     = "#E65100"
            fillcolor = "#FFF3E0"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        DelegationHandler [
            style     = "filled,rounded"
            fillcolor = "#FFE0B2"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>DelegationHandler [8]</B></TD></TR>
                <TR><TD>delegate:agent_spawned | completed | resumed | cancelled | error</TD></TR>
                <TR><TD>Node: :Delegation :SST_EVENT | :Agent :SST_CONCEPT</TD></TR>
                <TR><TD>Edges: HAS_AGENT (E01) | ENCOMPASSES (E02) | TRIGGERED (E03) | PARALLEL_AGENT (E04)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Intra-handler: _parallel_groups dict</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads: data_layer_3.active_recipe_step_id</I></TD></TR>
            </TABLE>>
        ]

        SkillLoadHandler [
            style     = "filled,rounded"
            fillcolor = "#FFE0B2"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>SkillLoadHandler [9]</B></TD></TR>
                <TR><TD>skill:loaded | skill:unloaded</TD></TR>
                <TR><TD>Node: :SkillLoad :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_SKILL_LOAD (E05)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Intra-handler: _active_skill_nodes dict</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads: data_layer_2.active_iteration_id (cross-layer read-only)</I></TD></TR>
            </TABLE>>
        ]

        RecipeRunHandler [
            style     = "filled,rounded"
            fillcolor = "#FFE0B2"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>RecipeRunHandler [10]</B></TD></TR>
                <TR><TD>recipe:start | complete | approval | loop_iteration | loop_complete</TD></TR>
                <TR><TD>Node: :RecipeRun :SST_EVENT | :Recipe :SST_CONCEPT</TD></TR>
                <TR><TD>Edges: HAS_RECIPE_RUN (E06) | HAS_RECIPE (E07) | SPAWNED (E09)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Writes: active_recipe_run_stack (push/pop)</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads: active_recipe_step_id</I></TD></TR>
            </TABLE>>
        ]

        RecipeStepHandler [
            style     = "filled,rounded"
            fillcolor = "#FFE0B2"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>RecipeStepHandler [11]</B></TD></TR>
                <TR><TD>recipe:step | approval | loop_iteration | tool:pre</TD></TR>
                <TR><TD>Node: :RecipeStep :SST_EVENT</TD></TR>
                <TR><TD>Edges: HAS_STEP (E08) | TRIGGERED (E10, E11)</TD></TR>
                <TR><TD ALIGN="LEFT"><I>Writes: active_recipe_step_id</I></TD></TR>
                <TR><TD ALIGN="LEFT"><I>Reads: active_recipe_run_stack (peek top)</I></TD></TR>
            </TABLE>>
        ]
    }

    // --- DataLayer2State (shared per-session state) --------------------------
    subgraph cluster_state {
        graph [
            label     = "handlers/data_layer_2/state.py\nShared per-session cross-handler state"
            style     = "filled"
            color     = "#F57F17"
            fillcolor = "#FFF8E1"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        DataLayer2State [
            style     = "filled,rounded"
            fillcolor = "#FFE082"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>DataLayer2State</B></TD></TR>
                <TR><TD>execution_start_ts: str | None</TD></TR>
                <TR><TD>active_iteration_id: str | None</TD></TR>
                <TR><TD>pending_tool_block_ids: dict[str, str]</TD></TR>
                <TR><TD>last_prompt_id: str | None</TD></TR>
                <TR><TD>last_completed_orch_run_id: str | None</TD></TR>
                <TR><TD>iteration_count: int</TD></TR>
            </TABLE>>
        ]
    }

    // --- DataLayer3State (shared per-session state) --------------------------
    subgraph cluster_data_layer_3_state {
        graph [
            label     = "handlers/data_layer_3/state.py\nShared per-session cross-handler state"
            style     = "filled"
            color     = "#E65100"
            fillcolor = "#FFF8E1"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        DataLayer3State [
            style     = "filled,rounded"
            fillcolor = "#FFCC80"
            label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
                <TR><TD><B>DataLayer3State</B></TD></TR>
                <TR><TD>active_recipe_run_stack: list[str]</TD></TR>
                <TR><TD>active_recipe_step_id: str | None</TD></TR>
            </TABLE>>
        ]
    }

    // --- Warning note --------------------------------------------------------
    warning_note [
        style     = "filled"
        fillcolor = "#FFF9C4"
        label     = "\u26a0 IMPORTANT\nClaiming an event does NOT prevent\nDefaultHandler from running.\nEnrichers are ADDITIVE \u2014 DefaultHandler\nalways creates the base Event node first."
    ]

    // --- Legend --------------------------------------------------------------
    subgraph cluster_legend {
        graph [
            label     = "Legend"
            style     = "filled"
            color     = "#BDBDBD"
            fillcolor = "#F5F5F5"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        legend_contract [
            style     = "filled,rounded"
            fillcolor = "#BBDEFB"
            label     = "blue = shared contract\n(protocol.py)"
        ]
        legend_capture [
            style     = "filled,rounded"
            fillcolor = "#C8E6C9"
            label     = "green = raw capture\n(data_layer_1)"
        ]
        legend_enrich [
            style     = "filled,rounded"
            fillcolor = "#E1BEE7"
            label     = "purple = semantic enrichment\n(data_layer_2)"
        ]
        legend_state [
            style     = "filled,rounded"
            fillcolor = "#FFE082"
            label     = "amber = shared state\n(DataLayer2State)"
        ]
        legend_http [
            style     = "filled,rounded"
            fillcolor = "#E0E0E0"
            label     = "grey = HTTP routers\n(separate concern)"
        ]
        legend_warning [
            style     = "filled"
            fillcolor = "#FFF9C4"
            label     = "yellow = warning / note"
        ]
        legend_layer3 [
            style     = "filled,rounded"
            fillcolor = "#FFE0B2"
            label     = "orange = foundation layer\n(data_layer_3)"
        ]

        legend_contract -> legend_capture -> legend_enrich -> legend_state -> legend_http -> legend_warning -> legend_layer3 [style = invis]
    }

    // --- Structural edges ----------------------------------------------------
    PipelineHandlers -> DefaultHandler             [label = "default"]
    PipelineHandlers -> SessionHandler             [label = "enrichers[0]"]
    PipelineHandlers -> OrchestratorRunHandler     [label = "enrichers[1]"]
    PipelineHandlers -> IterationHandler           [label = "enrichers[2]"]
    PipelineHandlers -> ContentBlockHandler        [label = "enrichers[3]"]
    PipelineHandlers -> ToolCallHandler            [label = "enrichers[4]"]
    PipelineHandlers -> PromptHandler              [label = "enrichers[5]"]
    PipelineHandlers -> CancellationHandler        [label = "enrichers[6]"]
    PipelineHandlers -> ContextCompactionHandler   [label = "enrichers[7]"]
    PipelineHandlers -> DelegationHandler          [label = "enrichers[8]"]
    PipelineHandlers -> SkillLoadHandler           [label = "enrichers[9]"]
    PipelineHandlers -> RecipeRunHandler           [label = "enrichers[10]"]
    PipelineHandlers -> RecipeStepHandler          [label = "enrichers[11]"]

    DefaultHandler -> warning_note [style = dotted, color = "#AAAAAA", arrowhead = none]

    // Protocol conformance (all handlers implement EventHandler)
    DefaultHandler          -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    SessionHandler          -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    OrchestratorRunHandler  -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    IterationHandler        -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    ContentBlockHandler     -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    ToolCallHandler         -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    PromptHandler           -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    CancellationHandler     -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    ContextCompactionHandler -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    DelegationHandler        -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    SkillLoadHandler         -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    RecipeRunHandler         -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]
    RecipeStepHandler        -> Protocol [style = dashed, color = "#90CAF9", arrowhead = empty, label = "implements"]

    // --- State read / write arrows (constraint=false to preserve layout) -----
    // OrchestratorRunHandler
    OrchestratorRunHandler -> DataLayer2State [
        label      = "writes execution_start_ts\nlast_completed_orch_run_id"
        color      = "#1565C0"
        fontcolor  = "#1565C0"
        style      = "bold"
        constraint = false
    ]
    DataLayer2State -> OrchestratorRunHandler [
        label      = "reads last_prompt_id"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]

    // IterationHandler
    IterationHandler -> DataLayer2State [
        label      = "writes active_iteration_id\niteration_count"
        color      = "#1565C0"
        fontcolor  = "#1565C0"
        style      = "bold"
        constraint = false
    ]
    DataLayer2State -> IterationHandler [
        label      = "reads execution_start_ts"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]

    // ContentBlockHandler
    ContentBlockHandler -> DataLayer2State [
        label      = "writes pending_tool_block_ids"
        color      = "#1565C0"
        fontcolor  = "#1565C0"
        style      = "bold"
        constraint = false
    ]
    DataLayer2State -> ContentBlockHandler [
        label      = "reads active_iteration_id"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]

    // ToolCallHandler
    DataLayer2State -> ToolCallHandler [
        label      = "reads active_iteration_id\npending_tool_block_ids"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]

    // PromptHandler
    PromptHandler -> DataLayer2State [
        label      = "writes last_prompt_id"
        color      = "#1565C0"
        fontcolor  = "#1565C0"
        style      = "bold"
        constraint = false
    ]
    DataLayer2State -> PromptHandler [
        label      = "reads last_completed_orch_run_id"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]

    // Layer 3 state read / write arrows
    RecipeRunHandler -> DataLayer3State [
        label      = "writes active_recipe_run_stack"
        color      = "#1565C0"
        fontcolor  = "#1565C0"
        style      = "bold"
        constraint = false
    ]
    DataLayer3State -> RecipeRunHandler [
        label      = "reads active_recipe_step_id"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]
    RecipeStepHandler -> DataLayer3State [
        label      = "writes active_recipe_step_id"
        color      = "#1565C0"
        fontcolor  = "#1565C0"
        style      = "bold"
        constraint = false
    ]
    DataLayer3State -> RecipeStepHandler [
        label      = "reads active_recipe_run_stack"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]
    DataLayer3State -> DelegationHandler [
        label      = "reads active_recipe_step_id"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]
    DataLayer2State -> SkillLoadHandler [
        label      = "reads active_iteration_id (cross-layer read)"
        color      = "#2E7D32"
        fontcolor  = "#2E7D32"
        style      = "dashed"
        arrowhead  = open
        constraint = false
    ]
}
