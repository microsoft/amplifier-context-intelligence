digraph auth_flow {
    // -- Global defaults -----------------------------------------------------------
    graph [
        rankdir   = TB
        splines   = ortho
        compound  = true
        nodesep   = 0.6
        ranksep   = 0.8
        fontname  = "Helvetica"
        fontsize  = 11
        label     = "Per-Request Authentication Flow \u2014 M2 dual-path\n(auth.py \u2014 BearerTokenMiddleware  \u00b7  EntraResolver (user + service paths)  \u00b7  per-route require_write / require_read)"
        labelloc  = t
        labeljust = c
    ]
    node [
        fontname = "Helvetica"
        fontsize = 11
        style    = "filled,rounded"
        shape    = box
    ]
    edge [
        fontname = "Helvetica"
        fontsize = 10
    ]

    // ====================================================================
    // ENTRY
    // ====================================================================
    Client [
        label     = "HTTP client\nAuthorization: Bearer <token>"
        shape     = oval
        fillcolor = "#E3F2FD"
    ]

    // ====================================================================
    // BEARER TOKEN MIDDLEWARE  (ASGI layer \u2014 sits before every HTTP route)
    // ====================================================================
    subgraph cluster_middleware {
        graph [
            label     = "BearerTokenMiddleware  (ASGI layer \u2014 auth.py)\nwraps the FastAPI app; intercepts every HTTP request before routing"
            style     = "filled"
            color     = "#006064"
            fillcolor = "#E0F7FA"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        IsHttpScope [
            label     = "scope[\"type\"] == \"http\"?"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        IsAuthEnabled [
            label     = "resolver.auth_enabled?\n(False only when allow_unauthenticated=True\n\u2014 test/dev opt-out, never production)"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        IsExemptPath [
            label     = "Exempt path?\nexact: _EXEMPT_PATHS (web_ui_enabled=True)\n  or _EXEMPT_PATHS_API_ONLY (web_ui_enabled=False)\nprefix: /static/ (always exempt)"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        ExtractToken [
            label     = "_extract_bearer_token(scope[\"headers\"])\nscan headers for Authorization: Bearer <token>"
            fillcolor = "#B2EBF2"
        ]

        HasToken [
            label     = "token extracted?"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        ResolveCall [
            label     = "resolver.resolve(token)\n(dispatched to active resolver\nwired at startup \u2014 see diagram 07)"
            fillcolor = "#80CBC4"
            fontname  = "Helvetica-Bold"
        ]

        AuthErrCatch [
            label     = "except AuthError as exc\nauth_event=auth_denied\nlog.info(reason, status_code=exc.status_code)"
            fillcolor = "#FFCCBC"
        ]

        ExcCatch [
            label     = "except Exception  (defense-in-depth catch-all)\nauth_event=resolver_unexpected_exception\nlog.error(exc_info=True)\nfail-closed \u2192 401  (never propagate as 500)"
            fillcolor = "#FFCCBC"
        ]

        ContribNone [
            label     = "contributor_id is None?\n(StaticKeyResolver miss \u2014 backward-compat path;\nEntraResolver always raises AuthError instead)"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        InjectIdentity [
            label     = "scope[\"state\"][\"contributor_id\"] = contributor_id\nscope[\"state\"][\"roles\"] = roles\n\u2192 await self.app(scope, receive, send)"
            fillcolor = "#C8E6C9"
            fontname  = "Helvetica-Bold"
            penwidth  = 2.5
        ]
    }

    // ====================================================================
    // STATIC KEY RESOLVER  (auth_mode=static)
    // ====================================================================
    subgraph cluster_static {
        graph [
            label     = "StaticKeyResolver  (auth_mode=static)  \u2014 auth.py\nPre-shared bearer tokens; pure dict lookup, no network calls"
            style     = "filled"
            color     = "#546E7A"
            fillcolor = "#ECEFF1"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        StaticHash [
            label     = "sha256(token.encode()).hexdigest()"
            fillcolor = "#F5F5F5"
        ]

        StaticLookup [
            label     = "keystore.get(sha256_hex)\n\u2192 contributor_id str  or  None\n(None on miss \u2014 never 'unknown')"
            fillcolor = "#F5F5F5"
        ]
    }

    // ====================================================================
    // ENTRA RESOLVER  (auth_mode=entra) \u2014 SHARED VALIDATION + USER PATH
    // ====================================================================
    subgraph cluster_entra {
        graph [
            label     = "EntraResolver  (auth_mode=entra)  \u2014 auth.py\nShared: JWKS sig / iss / aud / tid / exp (UNCHANGED)\nthen B1 idtyp-first fork \u2192 USER path (left) or SERVICE path (right) \u2192"
            style     = "filled"
            color     = "#0D47A1"
            fillcolor = "#E3F2FD"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        JwksKey [
            label     = "PyJWKClient.get_signing_key_from_jwt(token).key\n(per-kid cache; auto-refresh after lifespan boundary)"
            fillcolor = "#BBDEFB"
        ]

        JwtDecode [
            label     = "jwt.decode(token, key\n  algorithms=[\"RS256\"]  \u2190 H1: reject alg=none / HS256\n  audience=[client_id, \"api://client_id\"]\n  issuer=https://login.microsoftonline.com/{tenant_id}/v2.0\n  require=[\"exp\", \"iss\", \"aud\"])"
            fillcolor = "#BBDEFB"
        ]

        TidCheck [
            label     = "claims[\"tid\"] == tenant_id?\n(defense-in-depth alongside issuer pin)"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        // -- B1 / B2: idtyp-first decision  (NEW \u2014 placed BEFORE ScpCheck) --------
        IdtypCheck [
            label     = "B1: idtyp-first decision\n(B2) normalize idtyp: non-str\u2192\"\", lower/strip\n\nidtyp==\"app\" AND scp absent?   \u2192  SERVICE path\nscp present AND idtyp!=\"app\"?  \u2192  USER path\nelse (ambiguous token)          \u2192  AuthError(401) fail-closed"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        // -- USER PATH  (existing \u2014 VISUALLY AND BEHAVIORALLY UNCHANGED) --------
        ScpCheck [
            label     = "\"access_as_user\" in\nclaims.get(\"scp\", \"\").split()?"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        OidCheck [
            label     = "oid = claims.get(\"oid\")\nisinstance(oid, str) and oid.strip() != \"\"?"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        IdentityLookup [
            label     = "identity_map.get(oid.lower())\n\u2192 contributor_id str  or  None\n(entra_identities \u2014 human oid map)"
            fillcolor = "#BBDEFB"
        ]

        OidMapped [
            label     = "contributor_id found?\n(mapped human oid)"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]
    }

    // ====================================================================
    // SERVICE PATH  (NEW \u2014 M2: inside EntraResolver, parallel to user path)
    // ====================================================================
    subgraph cluster_service {
        graph [
            label     = "SERVICE PATH  (M2 new \u2014 inside EntraResolver)\napp/service tokens: idtyp==\"app\", scp absent\nManaged Identity / Federated Credential (GitHub OIDC / CI)"
            style     = "filled"
            color     = "#2E7D32"
            fillcolor = "#E8F5E9"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        RoleGate [
            label     = "Role gate \u2014 SOLE authz gate for service path\nroles \u220b Contributor   \u2192  write + read\nroles \u220b Reader        \u2192  read only\nroles \u220b IdentityAdmin  \u2192  admin\nNo role present?"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        ServiceCreatedBy [
            label     = "created_by derivation  (STABLE CLAIMS ONLY \u2014 D7)\nTrusted map: service_identities[oid] \u2192 friendly name\n  (optional override \u2014 NOT a gate; no unmapped\u2192403 here)\nFallback (truthiness, NOT key-presence):\n  appid  \u2192  azp  \u2192  oid\nNEVER app_displayname  (caller-spoofable, often absent)\nFail-loud 403 if all stable claims absent  (B8)"
            fillcolor = "#BBDEFB"
        ]

        ServiceContrib [
            label     = "contributor_id = stable service id (str \u2014 never null)\n  map name (\"ci-pipeline\") or Azure GUID (appid/oid)\nroles = token roles claim\n\u2192 return (contributor_id, roles)"
            fillcolor = "#C8E6C9"
            fontname  = "Helvetica-Bold"
            penwidth  = 2.5
        ]
    }

    // ====================================================================
    // EXIT NODES
    // ====================================================================
    PassThrough [
        label     = "pass-through to route\n(no auth check)"
        shape     = oval
        fillcolor = "#E3F2FD"
    ]

    Exit401NoToken [
        label     = "HTTP 401\nMissing or invalid bearer token"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    Exit401Auth [
        label     = "HTTP 401  (auth_denied)"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    Exit403Auth [
        label     = "HTTP 403  (auth_denied)\nUser path: oid valid but not in identity_map\noperator action: add oid to entra_identities config"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    Exit403ServiceNoRole [
        label     = "HTTP 403  (service \u2014 no role)\n\"app <appid> has no Contributor/Reader role\non this API \u2014 assign one in Entra app-role assignments\"\n(names missing role \u2014 acceptance criterion D7)"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    // ====================================================================
    // PER-ROUTE AUTHORIZATION  (D2 \u2014 downstream of identity injection)
    // ====================================================================
    subgraph cluster_per_route_authz {
        graph [
            label     = "Per-Route Authorization  (D2 \u2014 auth.py)\nDepends(require_write) on POST /events\nDepends(require_read)  on POST /cypher + GET /blobs/*\nApplied after identity injection; before route handler"
            style     = "filled"
            color     = "#E65100"
            fillcolor = "#FFF8E1"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        RequireWrite [
            label     = "require_write  (POST /events)\nwrite-capable iff:\n  mapped contributor (str) AND roles\u220bContributor\n  OR service path with roles\u220bContributor\n(B3: contributor_id must be non-null \u2014 None \u2192 403)"
            fillcolor = "#FFF3E0"
            fontname  = "Helvetica-Bold"
        ]

        RequireRead [
            label     = "require_read  (POST /cypher, GET /blobs/*)\nread-capable iff:\n  write-capable (above)\n  OR roles\u220bReader\nReader \u2192 write route = 403"
            fillcolor = "#FFF3E0"
            fontname  = "Helvetica-Bold"
        ]
    }

    Exit403RouteAuthz [
        label     = "HTTP 403  (insufficient capability)\nReader \u2192 write route: \"missing write capability\"\nor no read capability\n(names missing capability \u2014 acceptance criterion D2)"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    DataReadExit [
        label     = "POST /cypher / GET /blobs/* handler\n(route processes read request \u2192 200)"
        shape     = oval
        fillcolor = "#E3F2FD"
    ]

    // ====================================================================
    // PATH DISPATCH  (after identity injected)
    // ====================================================================
    PathDispatch [
        label     = "Request path?"
        shape     = diamond
        fillcolor = "#FFF9C4"
        style     = filled
    ]

    AdminPath [
        label     = "/admin/* handler  (routers/admin.py)\nrequire_admin: static \u2192 is_admin check  \u00b7  entra \u2192 IdentityAdmin role check\nIdentityStore.put/delete  (write-file-then-swap, ROB F2)\nlive flat_dict updated  \u2192  resolver sees change immediately\n(see diagram 08 for full admin management flow)"
        fillcolor = "#FFF3E0"
        fontname  = "Helvetica-Bold"
    ]

    ExitAdminResponse [
        label     = "HTTP 200 / 403 / 409 / 422 / 503\n(see diagram 08)"
        shape     = oval
        fillcolor = "#E3F2FD"
    ]

    // ====================================================================
    // POST /events HANDLER  (main.py)
    // ====================================================================
    subgraph cluster_post_events {
        graph [
            label     = "POST /events  (main.py \u2014 post_events)\ncontributor_id verified non-null by require_write; stamped before queue append"
            style     = "filled"
            color     = "#1565C0"
            fillcolor = "#E3F2FD"
            fontname  = "Helvetica"
            fontsize  = 10
        ]

        ValidateTimestamp [
            label     = "_validate_data_timestamp(data)\ndata[\"timestamp\"] must be:\n  present  +  non-empty string  +  valid ISO-8601\n(fail loud at boundary \u2014 never silently dead-letter)"
            fillcolor = "#F5F5F5"
        ]

        IdempotencyCheck [
            label     = "idempotency_key seen before?\n(EventIdempotencyCache)"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        WorkerKey [
            label     = "worker_key =\nsession_id  or  _no_session__<workspace-slug>"
            fillcolor = "#F5F5F5"
        ]

        GetOrCreate [
            label     = "registry.get_or_create(worker_key, workspace)\n(spawn sticky drainer if new session)"
            fillcolor = "#F5F5F5"
        ]

        StampCreatedBy [
            label     = "body_obj[\"created_by\"] = contributor_id\n(unconditional overwrite \u2014 prevents client spoofing)\n(B3: contributor_id always non-null here \u2014 require_write enforces)\nre-serialize as compact JSON"
            fillcolor = "#F5F5F5"
        ]

        QueueAppend [
            label     = "QueueManager.append(worker_key, stamped_body)\nPERSIST-FIRST: append to <worker_key>.log\n(drain loop \u2014 see diagram 05)"
            fillcolor = "#C8E6C9"
            fontname  = "Helvetica-Bold"
            penwidth  = 2.5
        ]

        RecordAccepted [
            label     = "registry.record_accepted()"
            fillcolor = "#F5F5F5"
        ]
    }

    Exit400 [
        label     = "HTTP 400\ndata.timestamp missing / empty / non-ISO-8601"
        shape     = oval
        fillcolor = "#FFCCBC"
    ]

    Exit202Dup [
        label     = "HTTP 202  {status: duplicate}"
        shape     = oval
        fillcolor = "#E3F2FD"
    ]

    Exit202 [
        label     = "HTTP 202  {status: queued}"
        shape     = oval
        fillcolor = "#E3F2FD"
    ]

    // ====================================================================
    // MIDDLEWARE FLOW EDGES
    // ====================================================================
    Client        -> IsHttpScope
    IsHttpScope   -> PassThrough    [label = "non-HTTP\n(WebSocket etc.)"]
    IsHttpScope   -> IsAuthEnabled  [label = "HTTP"]
    IsAuthEnabled -> PassThrough    [label = "False\n(allow_unauthenticated=True\ntest/dev only)"]
    IsAuthEnabled -> IsExemptPath   [label = "True"]
    IsExemptPath  -> PassThrough    [label = "yes"]
    IsExemptPath  -> ExtractToken   [label = "no"]
    ExtractToken  -> HasToken
    HasToken      -> Exit401NoToken [label = "None\n(missing or\nno Bearer prefix)"]
    HasToken      -> ResolveCall    [label = "token string"]

    // Dispatch branches to resolvers
    ResolveCall   -> StaticHash     [label = "auth_mode=static"]
    ResolveCall   -> JwksKey        [label = "auth_mode=entra"]

    // Catch-all from resolver.resolve()
    ResolveCall   -> ExcCatch       [label = "unexpected Exception\n(from any resolver)", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    ExcCatch      -> Exit401Auth

    // AuthError dispatcher
    AuthErrCatch  -> Exit401Auth    [label = "status_code=401"]
    AuthErrCatch  -> Exit403Auth    [label = "status_code=403"]

    // contributor_id=None check (after resolver returns)
    ContribNone   -> Exit401NoToken [label = "None\n(StaticKeyResolver miss)"]
    ContribNone   -> InjectIdentity [label = "str"]

    // ====================================================================
    // STATIC RESOLVER EDGES
    // ====================================================================
    StaticHash    -> StaticLookup
    StaticLookup  -> ContribNone    [label = "result (str or None)"]

    // ====================================================================
    // ENTRA RESOLVER EDGES \u2014 SHARED VALIDATION
    // ====================================================================
    JwksKey       -> JwtDecode
    JwtDecode     -> TidCheck       [label = "claims decoded"]
    TidCheck      -> IdtypCheck     [label = "tid match"]

    // B1: idtyp-first fork  (NEW \u2014 BEFORE ScpCheck)
    IdtypCheck    -> ScpCheck       [label = "scp present\nAND idtyp != \"app\"\n\u2192 USER path"]
    IdtypCheck    -> RoleGate       [label = "idtyp==\"app\"\nAND scp absent\n\u2192 SERVICE path"]
    IdtypCheck    -> AuthErrCatch   [label = "else (ambiguous\ne.g. scp+idtyp=app)\n\u2192 AuthError(401)\nfail closed", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]

    // Shared JWKS / JWT failure exits (all raise AuthError \u2014 caught by middleware)
    JwksKey       -> AuthErrCatch   [label = "PyJWTError\n\u2192 AuthError(401)",          style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    JwtDecode     -> AuthErrCatch   [label = "PyJWTError\n\u2192 AuthError(401)",          style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    TidCheck      -> AuthErrCatch   [label = "wrong tenant\n\u2192 AuthError(401)",        style = dashed, color = "#BF360C", fontcolor = "#BF360C"]

    // USER PATH edges  (UNCHANGED \u2014 Option A: delegated path byte-for-byte identical)
    ScpCheck      -> OidCheck       [label = "scp ok\n(access_as_user)"]
    OidCheck      -> IdentityLookup [label = "valid str"]
    IdentityLookup -> OidMapped

    ScpCheck      -> AuthErrCatch   [label = "missing access_as_user\n\u2192 AuthError(401)", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    OidCheck      -> AuthErrCatch   [label = "non-str / empty oid\n\u2192 AuthError(401)", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    OidMapped     -> AuthErrCatch   [label = "None\n\u2192 AuthError(403)",               style = dashed, color = "#BF360C", fontcolor = "#BF360C"]

    // USER PATH success \u2014 contributor_id str returns to middleware ContribNone check
    OidMapped     -> ContribNone    [label = "contributor_id str\n(mapped human)"]

    // ====================================================================
    // SERVICE PATH EDGES  (NEW \u2014 M2)
    // ====================================================================
    // Role gate: SOLE authz gate; no role \u2192 direct 403 naming the missing role
    RoleGate      -> Exit403ServiceNoRole  [label = "no role\n\u2192 403\n(names missing role)", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    RoleGate      -> ServiceCreatedBy      [label = "role present\n(Contributor\n| Reader\n| IdentityAdmin)"]

    // created_by derivation: stable claims only; fail-loud if all absent
    ServiceCreatedBy -> AuthErrCatch       [label = "all stable claims\nabsent \u2192 403  (B8)", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    ServiceCreatedBy -> ServiceContrib     [label = "contributor_id\nresolved"]

    // Service success \u2014 contributor_id str (stable id) returns to middleware
    ServiceContrib -> ContribNone          [label = "contributor_id str\n(stable service id)"]

    // ====================================================================
    // POST-INJECT PATH DISPATCH
    // ====================================================================
    InjectIdentity  -> PathDispatch
    PathDispatch    -> AdminPath         [label = "/admin/*"]
    PathDispatch    -> RequireWrite      [label = "POST /events"]
    PathDispatch    -> RequireRead       [label = "POST /cypher\nGET /blobs/*"]
    AdminPath       -> ExitAdminResponse

    // Per-route capability checks
    RequireWrite    -> ValidateTimestamp [label = "write-capable\n\u2192 proceed"]
    RequireWrite    -> Exit403RouteAuthz [label = "no write cap\n\u2192 403", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]
    RequireRead     -> DataReadExit      [label = "read-capable\n\u2192 proceed"]
    RequireRead     -> Exit403RouteAuthz [label = "no read cap\n\u2192 403", style = dashed, color = "#BF360C", fontcolor = "#BF360C"]

    // ====================================================================
    // POST /events FLOW EDGES
    // ====================================================================
    ValidateTimestamp -> Exit400           [label = "invalid"]
    ValidateTimestamp -> IdempotencyCheck  [label = "valid"]
    IdempotencyCheck  -> Exit202Dup        [label = "yes (duplicate)"]
    IdempotencyCheck  -> WorkerKey         [label = "no"]
    WorkerKey         -> GetOrCreate
    GetOrCreate       -> StampCreatedBy
    StampCreatedBy    -> QueueAppend
    QueueAppend       -> RecordAccepted
    RecordAccepted    -> Exit202

    // ====================================================================
    // LEGEND
    // ====================================================================
    subgraph cluster_legend {
        graph [
            label     = "Legend"
            fontsize  = 10
            fontname  = "Helvetica"
            style     = "dashed"
            color     = "#AAAAAA"
        ]
        node [fontsize = 10]

        LegTeal [
            label     = "auth middleware"
            fillcolor = "#B2EBF2"
        ]
        LegBlue [
            label     = "Entra JWT validation\n(shared + user path)"
            fillcolor = "#BBDEFB"
        ]
        LegGreen [
            label     = "critical path / success"
            fillcolor = "#C8E6C9"
            fontname  = "Helvetica-Bold"
            penwidth  = 2.5
        ]
        LegServiceGreen [
            label     = "service path cluster\n(M2 new)"
            fillcolor = "#E8F5E9"
        ]
        LegRouteAuthz [
            label     = "handler-level node\n(/admin/* \u00b7 require_write \u00b7 require_read)"
            fillcolor = "#FFF3E0"
            fontname  = "Helvetica-Bold"
        ]
        LegOval [
            label     = "HTTP boundary"
            shape     = oval
            fillcolor = "#E3F2FD"
        ]
        LegError [
            label     = "error / rejection"
            shape     = oval
            fillcolor = "#FFCCBC"
        ]
        LegDecision [
            label     = "decision"
            shape     = diamond
            fillcolor = "#FFF9C4"
            style     = filled
        ]

        LegTeal -> LegBlue -> LegGreen -> LegServiceGreen -> LegRouteAuthz -> LegOval -> LegError -> LegDecision [style = invis]
    }
}
