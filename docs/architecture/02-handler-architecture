digraph handler_architecture {
    // ── Global defaults ───────────────────────────────────────────────────────
    graph [
        rankdir   = TB
        splines   = ortho
        nodesep   = 0.8
        ranksep   = 0.9
        fontname  = "Helvetica"
        fontsize  = 11
        label     = "Handler Registry Structure\n(PipelineHandlers — default + enrichers[])"
        labelloc  = t
        labeljust = c
    ]
    node [
        fontname = "Helvetica"
        fontsize = 11
        style    = "filled,rounded"
        shape    = box
    ]
    edge [
        fontname = "Helvetica"
        fontsize = 10
    ]

    // ── PipelineHandlers (NamedTuple record) ──────────────────────────────────
    PipelineHandlers [
        shape     = record
        style     = "filled"
        fillcolor = "#E3F2FD"
        label     = "{PipelineHandlers (NamedTuple) | default: DefaultHandler | enrichers: list[Handler]}"
    ]

    // ── DefaultHandler (ALWAYS — unconditional base layer) ────────────────────
    DefaultHandler [
        shape     = box
        style     = "filled,rounded"
        fillcolor = "#C8E6C9"
        fontname  = "Helvetica-Bold"
        penwidth  = 2.5
        label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
            <TR><TD><B>DefaultHandler</B></TD></TR>
            <TR><TD>UNCONDITIONAL &#8212; ALL events</TD></TR>
            <TR><TD>handled_events = set() (empty &#8212; accepts everything)</TD></TR>
            <TR><TD>Field Lifting: ALL matching FieldLifters fire (not first-match-wins)</TD></TR>
            <TR><TD>Creates [:FullPascalEvent, :CategoryEvent, :Event] node + lifted top-level props</TD></TR>
            <TR><TD>Creates (Session)-[:HAS_EVENT]-&gt;(Event) edge</TD></TR>
            <TR><TD>See: 04-default-handler-flow.dot for internal pipeline detail</TD></TR>
        </TABLE>>
    ]

    // ── Enrichers ordered list label ──────────────────────────────────────────
    enrichers_label [
        shape     = plaintext
        style     = ""
        fillcolor = "transparent"
        label     = "enrichers[] — ordered by priority index"
    ]

    // ── SessionHandler [0] ────────────────────────────────────────────────────
    SessionHandler [
        shape     = box
        style     = "filled,rounded"
        fillcolor = "#F3E5F5"
        label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
            <TR><TD><B>SessionHandler [0]</B></TD></TR>
            <TR><TD>session:start | session:fork | session:end</TD></TR>
            <TR><TD>Labels: RootSession:Session | SubSession:Session | ForkedSession:Session</TD></TR>
            <TR><TD>session:start &#8594; SUBSESSION_OF | session:fork &#8594; HAS_FORK</TD></TR>
            <TR><TD>(both parent&#8594;child — ForkedSession is NOT a SubSession)</TD></TR>
            <TR><TD>Sets: started_at / ended_at / workspace</TD></TR>
        </TABLE>>
    ]

    // ── ToolCallHandler [1] ───────────────────────────────────────────────────
    ToolCallHandler [
        shape     = box
        style     = "filled,rounded"
        fillcolor = "#F3E5F5"
        label     = <<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2" CELLPADDING="3">
            <TR><TD><B>ToolCallHandler [1]</B></TD></TR>
            <TR><TD>tool:pre | tool:post | tool:error</TD></TR>
            <TR><TD>Node: :ToolCall (session_id__tool_call__tool_call_id)</TD></TR>
            <TR><TD>Edges: HAS_TOOL_CALL / HAS_EVENT</TD></TR>
            <TR><TD>Correlates: pre&#8594;post/error via tool_call_id</TD></TR>
        </TABLE>>
    ]

    // ── FutureHandler [N] (extension point) ───────────────────────────────────
    FutureHandler [
        shape     = box
        style     = "filled,rounded,dashed"
        fillcolor = "#FAFAFA"
        color     = "#AAAAAA"
        fontcolor = "#AAAAAA"
        label     = "FutureHandler [N]\n… extension point …"
    ]

    // ── Warning note ──────────────────────────────────────────────────────────
    note [
        shape     = box
        style     = "filled"
        fillcolor = "#FFF9C4"
        label     = "⚠ IMPORTANT\nClaiming an event does NOT prevent\nDefaultHandler from running.\nEnrichers are ADDITIVE — DefaultHandler\nalways creates the base Event node first."
    ]

    // ── Edges ─────────────────────────────────────────────────────────────────
    PipelineHandlers -> DefaultHandler   [label = "default"]
    PipelineHandlers -> enrichers_label  [label = "enrichers"]
    enrichers_label  -> SessionHandler
    enrichers_label  -> ToolCallHandler
    ToolCallHandler  -> FutureHandler    [style = dashed, color = "#AAAAAA"]
    DefaultHandler   -> note             [style = dotted, color = "#AAAAAA", arrowhead = none]
}
